# ─────────────────────────────────────────────────────────────────
# RouteForge VRP Optimizer – Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# Options: haversine | osrm | ors
# haversine = no API key, uses great-circle + 1.35x road-factor
# osrm      = free public OSRM or self-hosted
# ors       = OpenRouteService (requires ORS_API_KEY)
ROUTING_BACKEND=haversine

# Get a free key at https://openrouteservice.org/
ORS_API_KEY=

# Leave blank for public demo server (rate-limited for large jobs)
OSRM_BASE_URL=http://router.project-osrm.org

# OR-Tools time limit per solve call (seconds)
SOLVER_TIME_LIMIT_SECONDS=60

# Leave blank to use in-process LRU cache only
REDIS_URL=redis://localhost:6379/0

DEBUG=false
